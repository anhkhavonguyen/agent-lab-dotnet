<div class="flex flex-col items-center justify-center min-h-full p-6 bg-cozy-cream">
    <div class="text-center max-w-sm">
        <h1 class="text-5xl font-bold text-cozy-brown mb-2 font-cozy-display">Soc Ops</h1>
        <p class="text-lg text-cozy-dark mb-8 font-cozy">Social Bingo</p>

        <div class="bg-white rounded-cozy p-6 shadow-cozy border border-amber-100 mb-8">
            <h2 class="font-semibold text-cozy-brown mb-3 font-cozy">How to play</h2>
            <ul class="text-left text-cozy-dark text-sm space-y-2 font-cozy">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-cozy-orange text-white font-semibold py-4 px-8 rounded-cozy text-lg font-cozy transition-colors hover:bg-amber-700 active:bg-amber-800">
            Start Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
